FROM reactnativecommunity/react-native-android:latest
WORKDIR /app

# Pre-download Gradle with retries
RUN mkdir -p /root/.gradle/wrapper/dists/gradle-8.14.3-bin && \
    for i in 1 2 3 4 5; do \
      curl -fSL --retry 5 --retry-delay 10 -o /tmp/gradle.zip \
        https://services.gradle.org/distributions/gradle-8.14.3-bin.zip && break || sleep 30; \
    done

COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps
COPY . .
RUN npx expo prebuild --clean

# Configure Gradle
RUN echo "org.gradle.jvmargs=-Xmx4g -XX:MaxMetaspaceSize=512m" >> android/gradle.properties && \
    echo "org.gradle.parallel=true" >> android/gradle.properties

# Install pre-downloaded Gradle
RUN HASH=$(cat android/gradle/wrapper/gradle-wrapper.properties | grep distributionUrl | sed 's/.*\///' | sed 's/.zip//') && \
    mkdir -p "/root/.gradle/wrapper/dists/${HASH}" && \
    cp /tmp/gradle.zip "/root/.gradle/wrapper/dists/${HASH}/"

ENV GRADLE_OPTS="-Dorg.gradle.daemon=false"
ENV NODE_OPTIONS="--max_old_space_size=8192"

RUN cd android && chmod +x gradlew && ./gradlew assembleRelease --no-daemon
